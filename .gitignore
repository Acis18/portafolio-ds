# Extensiones de datos — nunca al repositorio
*.csv
*.dbf
*.xlsx
*.parquet

# Carpetas de datos
data/raw/*
data/processed/*

# Excepciones de datos
!data/raw/.gitkeep
!data/processed/.gitkeep
!docs/*.xlsx

# R
.Rhistory
.RData
.Rproj.user
*.Rproj

# renv — la librería no se versiona, solo el lockfile
renv/library/
renv/local/
renv/staging/
renv/.python/

# VSCode
.vscode/extensions.json

# Outputs generados
outputs/*.pdf
outputs/*.html
!outputs/.gitkeep

# Sistema
.DS_Store
Thumbs.db
__pycache__/
/.quarto/
**/*.quarto_ipynb
